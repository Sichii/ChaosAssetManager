<UserControl x:Class="ChaosAssetManager.Controls.HeaEditorControls.LightPrefabPickerEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:model="clr-namespace:ChaosAssetManager.Model"
             mc:Ignorable="d"
             d:DesignWidth="220"
             MinHeight="54"
             d:DesignHeight="54"
             Background="{DynamicResource MaterialDesignPaper}"
             TextElement.FontWeight="Medium"
             TextElement.FontSize="14"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             FontFamily="{materialDesign:MaterialDesignFont}"
             d:DataContext="{d:DesignInstance model:LightPrefab}"
             Padding="0"
             Margin="0"
             DataContextChanged="LightPrefabPickerEntry_OnDataContextChanged">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ContentControl x:Name="ContentControl"
                        Grid.Column="0"
                        Padding="0"
                        Margin="4" />
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="4,0">
            <TextBlock x:Name="IdText"
                       FontSize="12"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock x:Name="SizeText"
                       FontSize="10"
                       Opacity="0.6" />
        </StackPanel>
        <Button x:Name="DeleteBtn"
                Grid.Column="2"
                Width="24"
                Height="24"
                Padding="0"
                VerticalAlignment="Top"
                Margin="4"
                Style="{StaticResource MaterialDesignFlatButton}"
                Content="{materialDesign:PackIcon Kind=Delete, Size=16}"
                ToolTip="Delete Prefab"
                Click="DeleteBtn_OnClick" />
    </Grid>
</UserControl>
